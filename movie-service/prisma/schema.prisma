generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Movie {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subTitle    String?
  image       String   // Poster URL
  background  String?  // Hero backdrop URL
  rating      Float?   @default(0)
  duration    Int?     // in minutes
  description String?
  director    String?
  actors      String[] // array of actor names
  tags        String[] // ["Action", "Sci-Fi", ...]
  status      String   @default("NOW_SHOWING") // "COMING_SOON", "NOW_SHOWING", "ARCHIVED"
  releaseDate DateTime?
  
  showtimes   Showtime[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Cinema {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  address   String
  city      String

  showtimes Showtime[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Showtime {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  movieId     String   @db.ObjectId
  movie       Movie    @relation(fields: [movieId], references: [id])
  cinemaId    String   @db.ObjectId
  cinema      Cinema   @relation(fields: [cinemaId], references: [id])
  
  date        String   // e.g., "YYYY-MM-DD"
  time        String   // e.g., "19:30"
  format      String   // e.g., "IMAX 2D"
  price       Int      // e.g., 120000
  bookedSeats String[] // e.g., ["B1", "B2"]
  tickets     Ticket[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ticket {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  showtimeId  String   @db.ObjectId
  showtime    Showtime @relation(fields: [showtimeId], references: [id])

  orderId     String
  amount      Int
  seats       String[]
  status      String   @default("PAID")
  paymentType String   @default("MOMO")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
